# Server
PORT=3000
NODE_ENV=development

# CORS — comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Logs
LOG_DIR=logs

# Database — connection_limit e pool_timeout devem ser ajustados conforme a escala.
# Regra: INSTANCE_COUNT × DB_CONNECTION_LIMIT < limite máximo de conexões do banco.
# Para MySQL padrão (151 conexões), com 1 instância: connection_limit=5 é seguro.
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@DB_HOST:DB_PORT/DB_NAME?connection_limit=5&pool_timeout=10"

# Pool de conexões — deve ser consistente com ?connection_limit= no DATABASE_URL acima
DB_CONNECTION_LIMIT=5
# Número máximo de conexões configurado no banco (ex: MySQL max_connections)
# Defina para habilitar a validação automática no startup. 0 = desabilitado.
DB_MAX_CONNECTIONS=151
# Número de instâncias/pods da API em execução simultânea
INSTANCE_COUNT=1
