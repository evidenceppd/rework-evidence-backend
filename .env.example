# Server
PORT=3000
NODE_ENV=development

# CORS â comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Logs
LOG_DIR=logs

# Database â connection_limit e pool_timeout devem ser ajustados conforme a escala.
# Regra: INSTANCE_COUNT Ă DB_CONNECTION_LIMIT < limite mĂĄximo de conexĂ”es do banco.
# Para MySQL padrĂŁo (151 conexĂ”es), com 1 instĂąncia: connection_limit=5 Ă© seguro.
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@DB_HOST:DB_PORT/DB_NAME?connection_limit=5&pool_timeout=10"

# Pool de conexĂ”es â deve ser consistente com ?connection_limit= no DATABASE_URL acima
DB_CONNECTION_LIMIT=5
# NĂșmero mĂĄximo de conexĂ”es configurado no banco (ex: MySQL max_connections)
# Defina para habilitar a validaĂ§ĂŁo automĂĄtica no startup. 0 = desabilitado.
DB_MAX_CONNECTIONS=151
# NĂșmero de instĂąncias/pods da API em execuĂ§ĂŁo simultĂąnea
INSTANCE_COUNT=1

# Seed do painel admin
# Troque estes valores antes de popular staging/produĂ§ĂŁo.
SEED_ADMIN_EMAIL=master@evidence.local
SEED_ADMIN_PASSWORD=Master@123456
SEED_ADMIN_NAME=Master Admin

# MFA local
# Em development, por padrĂŁo o cĂłdigo MFA Ă© exibido no console e o envio SMTP pode ser pulado.
SMTP_LOG_MFA_CODE=true
SMTP_SKIP_SEND=true
# Email (SMTP)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=2fa@agenciaevidence.com.br
SMTP_PASS=senha-do-email-2fa
SMTP_FROM=2fa@agenciaevidence.com.br

# Email para receber os avisos de nova análise
SMTP_ANALISE_TO=sites.evidenceppd@gmail.com
SMTP_USER_ANALISE=analise@agenciaevidence.com.br
SMTP_PASS_ANALISE=senha-do-email-analise
SMTP_FROM_ANALISE=analise@agenciaevidence.com.br
